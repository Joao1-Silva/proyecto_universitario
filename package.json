{
  "name": "my-v0-project",
  "version": "0.1.0",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "check:windows": "node scripts/check-windows-compat.cjs",
    "build": "next build --webpack",
    "build:web": "next build --webpack",
    "build:renderer": "node scripts/build-renderer-export.cjs",
    "build:backend:runtime": "node scripts/build-backend-runtime.cjs",
    "build:electron:ts": "tsc -p electron/tsconfig.json",
    "build:electron": "npm run build:electron:ts",
    "build:app": "npm run build:renderer && npm run build:electron",
    "db:migrate": "cd backend && python -m app.migration_runner up",
    "db:migrate:down": "cd backend && python -m app.migration_runner down --steps=1",
    "db:migrate:status": "cd backend && python -m app.migration_runner status",
    "db:seed": "cd backend && python -m app.migration_runner seed",
    "dev": "npm run dev:electron",
    "dev:web": "next dev --webpack",
    "dev:web:electron": "next dev --webpack -p 3100 -H 127.0.0.1",
    "dev:electron:main": "npm run build:electron:ts && wait-on tcp:3100 && cross-env ELECTRON_RENDERER_URL=http://127.0.0.1:3100 node scripts/run-electron.cjs",
    "dev:electron": "concurrently -k -s command-ELECTRON -n WEB,ELECTRON -c blue,green \"npm:dev:web:electron\" \"npm:dev:electron:main\"",
    "dist:win": "npm run build:backend:runtime && npm run build:app && electron-builder --win --x64",
    "dist:win:arm64": "npm run build:backend:runtime && npm run build:app && electron-builder --win --arm64",
    "dist:win:all": "npm run build:backend:runtime && npm run build:app && electron-builder --win --x64 --arm64",
    "lint": "eslint .",
    "start": "next start"
  },
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "1.2.2",
    "@radix-ui/react-alert-dialog": "1.1.4",
    "@radix-ui/react-aspect-ratio": "1.1.1",
    "@radix-ui/react-avatar": "1.1.2",
    "@radix-ui/react-checkbox": "1.1.3",
    "@radix-ui/react-collapsible": "1.1.2",
    "@radix-ui/react-context-menu": "2.2.4",
    "@radix-ui/react-dialog": "1.1.4",
    "@radix-ui/react-dropdown-menu": "2.1.4",
    "@radix-ui/react-hover-card": "1.1.4",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-menubar": "1.1.4",
    "@radix-ui/react-navigation-menu": "1.2.3",
    "@radix-ui/react-popover": "1.1.4",
    "@radix-ui/react-progress": "1.1.1",
    "@radix-ui/react-radio-group": "1.2.2",
    "@radix-ui/react-scroll-area": "1.2.2",
    "@radix-ui/react-select": "2.1.4",
    "@radix-ui/react-separator": "1.1.1",
    "@radix-ui/react-slider": "1.2.2",
    "@radix-ui/react-slot": "1.1.1",
    "@radix-ui/react-switch": "1.1.2",
    "@radix-ui/react-tabs": "1.1.2",
    "@radix-ui/react-toast": "1.2.4",
    "@radix-ui/react-toggle": "1.1.1",
    "@radix-ui/react-toggle-group": "1.1.1",
    "@radix-ui/react-tooltip": "1.1.6",
    "@tanstack/react-table": "8.21.3",
    "@vercel/analytics": "1.3.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.0.4",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.5.1",
    "input-otp": "1.4.1",
    "lucide-react": "^0.454.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.0",
    "react-day-picker": "9.8.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.60.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.28.0",
    "baseline-browser-mapping": "^2.10.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "eslint": "^9.23.0",
    "postcss": "^8.5",
    "tailwindcss": "^4.1.9",
    "tw-animate-css": "1.3.3",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.aguilera21.sga",
    "productName": "SYMBIOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-dist/**",
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend-dist/backend-server",
        "to": "backend-runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "docs",
        "to": "docs",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "artifactName": "SYMBIOS-Setup-${version}.exe",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
